# URL мока TrueConf (с хоста из контейнера - host.docker.internal)
TRUECONF_BASE_URL=http://host.docker.internal:8080
TRUECONF_CLIENT_ID=test-client
TRUECONF_CLIENT_SECRET=test-secret

# PostgreSQL (сервис db из docker-compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app
